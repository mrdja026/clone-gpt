# Third Lane Architecture Configuration

# Lane A (Intent Detection) – Gemma via raw Ollama generate endpoint
# If you run Gemma on the default Windows Ollama port, this URL should be
# http://127.0.0.1:11434/api/generate. If you dedicate port 123 to Gemma,
# use http://127.0.0.1:123/api/generate.
OPENAI_BASE_URL=http://127.0.0.1:11434/api/generate
GEMMA_MODEL=gemma-fc-test:latest
LANE_A_HOST=127.0.0.1:123

# Lane B (MCP Data Fetching)
LANE_B_ENABLED=true

# Lane C (Analysis) – Qwen via raw Ollama chat endpoint
# If you dedicate port 124 to Qwen, keep /api/chat below; otherwise
# point to your actual Ollama chat endpoint.
MODEL_NAME=qwen2.5:7b
OLLAMA_URL=http://127.0.0.1:124/api/chat
LANE_C_HOST=127.0.0.1:124
LANE_C_TEMPERATURE=0.7
LANE_C_MAX_TOKENS=2048

# Force RAW_DATA-first replies; analysis only after follow-up prompt
LANE_C_DIRECT_ANALYSIS=0

# MCP External HTTP Server (required)
# Set to your external MCP bridge URL (e.g., hello-world-mcp HTTP bridge)
MCP_BASE_URL=http://127.0.0.1:4000

# Supabase Configuratiyeson (from prompt-branch-buddy project)
SUPABASE_URL=https://pvajezukfmmxnvzxortm.supabase.co
SUPABASE_ANON_KEY=dev_anon_key
SUPABASE_SERVICE_ROLE_KEY=dev_service_role_key

# Frontend Environment Variables (for Vite)
VITE_SUPABASE_ANON_KEY=dev_anon_key

# Optional: Custom ping message
PING_MESSAGE=ping

# Server Configuration
PORT=3001

# OAuth for Jira (optional for scoped access)
JIRA_OAUTH_CLIENT_ID=
JIRA_OAUTH_CLIENT_SECRET=
JIRA_OAUTH_AUDIENCE=api.atlassian.com
JIRA_CLOUD_ID=

# Notion Provider (example values for docs/demo)
NOTION_API_KEY=seccc
NOTION_DATABASE_ID=DBSC

# Perplexity API Configuration
PERPLEXITY_API_KEY=pplx-your-key-here
PERPLEXITY_API_BASE=https://api.perplexity.ai
PERPLEXITY_MODEL=sonar-pro

# RAG Space Configuration
RAG_SPACE_URL=https://www.perplexity.ai/spaces/rag-wsYHiyYKR9CuX4eJuKVqBg


