GEMMA_MODEL=gemma-fc-test:latest
LANE_A_HOST=127.0.0.1:123/v1

# Lane B (MCP Data Fetching) - No AI model needed
LANE_B_ENABLED=true

# Lane C (Analysis) - Uses Qwen2.5 for deep analysis  
MODEL_NAME=qwen2.5:7b
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
LANE_C_HOST=127.0.0.1:124/v1
LANE_C_TEMPERATURE=0.7
LANE_C_MAX_TOKENS=2048

# MCP Configuration (Forward-only by default)
